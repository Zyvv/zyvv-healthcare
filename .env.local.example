# ============================================================
# ZYVV — Environment Variables
# File: .env.local.example
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
#
# In production: add these to Vercel Dashboard →
# Settings → Environment Variables
# ============================================================

# ── Groq ──────────────────────────────────────────────────────
# Get your key at: https://console.groq.com/keys
# Model used: llama-3.1-70b-versatile
GROQ_API_KEY=

# ── Supabase ──────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
# ANON key is safe for client-side use (RLS protects data)
# SERVICE key is server-only — never expose to browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ── Resend ────────────────────────────────────────────────────
# Get your key at: https://resend.com/api-keys
# Verify your domain at: https://resend.com/domains
RESEND_API_KEY=
RESEND_FROM_EMAIL=reading@zyvv.app

# ── App ───────────────────────────────────────────────────────
# Used for Open Graph and canonical URLs
NEXT_PUBLIC_APP_URL=https://zyvv.app

# ── Python Intelligence Layer (Phase 3) ───────────────────────
# Only needed when the Python microservice is active
# PYTHON_SERVICE_URL=http://localhost:8000
# OPENAI_API_KEY=
