# ============================================================
# ZYVV — .gitignore
# ============================================================

# ── Environment variables — NEVER commit these ────────────────
.env
.env.local
.env.*.local
.env.production

# ── Next.js ───────────────────────────────────────────────────
.next/
out/
build/

# ── Node ──────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
*.egg

# trigger deploy

.venv/
venv/
ENV/
.Python

# ── Vercel ────────────────────────────────────────────────────
.vercel

# ── TypeScript ────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── OS ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor ────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
